# Exchange rate API endpoint (e.g. from your preferred provider)
EXCHANGE_API=https://api.example.com/exchange-rates

# Threshold: send SMS alert when USD/LKR rate exceeds this value
LIMIT=300.00

# SMS recipient phone number (Sri Lanka format)
SMS_RECIPIENT=0771234567

# Dialog eSMS API credentials
ESMS_USERNAME=your-esms-username
ESMS_PASSWORD=your-esms-password

# SMS sender name (source address shown on the recipient's phone)
SMS_SOURCE_ADDRESS=Chutte

# Cache file for tracking last notified rate (default: .cache/last-rate.json)
# CACHE_FILE=.cache/last-rate.json
